# Database Connection (PostgreSQL via Drizzle)
DATABASE_URL=postgresql://dashly_user:dashly_password@localhost:5432/dashly_db

# Authentication (required; generate JWT_SECRET with: openssl rand -base64 48)
JWT_SECRET=
GOOGLE_CLIENT_ID=

# Redis Connection (Geospatial & Real-time caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT (EMQX Broker) Connection
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=8083

# EMQX Dashboard
EMQX_DASHBOARD_PORT=18083

# Production image published by GitHub Actions to GHCR.
BACKEND_IMAGE=ghcr.io/fikuraru72/dashly-backend:latest
API_REPLICAS=2
WORKER_REPLICAS=2

# OSRM bicycle routing. Production Compose overrides URL to its internal service.
OSRM_ENABLED=true
OSRM_URL=http://localhost:5000
OSRM_PROFILE=bicycle
OSRM_REGION=java
OSRM_MAX_SNAP_DISTANCE_METERS=100
OSRM_IMAGE=ghcr.io/project-osrm/osrm-backend:v26.7.3-debian
OSRM_PBF_URL=https://download.geofabrik.de/asia/indonesia/java-latest.osm.pbf
OSRM_VOLUME=dashly-osrm-bicycle
