  "scripts": {
    "build": "nest build",
    "format": "vp fmt --write",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "seed": "ts-node src/db/seed.ts",
    "db:reset": "ts-node src/db/reset.ts && vp exec drizzle-kit push --force && ts-node src/db/seed.ts",
    "lint": "vp lint",
    "test": "vp test",
    "test:watch": "vp test watch",
    "test:cov": "vp test --coverage",
    "test:debug": "vp test --inspect-brk --no-file-parallelism",
    "test:e2e": "vp test test/app.e2e-spec.ts"
  },
